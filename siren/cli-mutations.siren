# CLI mutation support for Siren
# This initiative defines the first pass at mutative CLI operations, starting with status changes.
# 
# Reshape (post language-ast-pipeline rebuild): the "literal SirenDocument renderer" shipped in
# cli-mutations-language-renderer was superseded by per-entry surgical rendering in @sirenpm/language
# (renderEntry + ParsedDocument.patchEntry/removeEntry/format/source). The CLI write path is now built
# on an explicit lifecycle rewrite signal that both `format` (no IR mutation) and IR mutations feed.
# `format` is no longer an exception, and the IR-patch -> source write-back bridge is now its own task.
# All remaining work is apps/cli-only: core@0.6.1 already returns PatchResult and language@0.5.0 already
# exposes patchEntry/removeEntry/source, so no further core/language release is required.
milestone cli-mutations {
  description = "Deliver the first mutative CLI flow: an immutable SirenBuilder patch layer (core), per-entry source rendering (language), a lifecycle rewrite-signal write-back with an IR-patch-to-source bridge and de-exceptionalized format (apps/cli), and the mv status command."
  affected_packages = "core, language, apps/cli"
  depends_on = [cli-mutations-remove-core-export-surface, cli-mutations-core-patch-api, cli-mutations-language-renderer, cli-mutations-publish-core-language, cli-mutations-cli-plumbing, cli-mutations-writeback-signal, cli-mutations-ir-source-bridge, cli-mutations-format-lifecycle, cli-mutations-mv-command]
}
# Core surface cleanup and mutation primitives
task cli-mutations-remove-core-export-surface complete {
  description = "Remove the current export surface from core so the package only owns IR and semantic validation."
  affected_packages = "core"
  details = "Delete IRExporter and any related public export types so project-to-source rendering stops being part of core's contract and moves entirely into language."
}

task cli-mutations-core-patch-api-red complete {
  description = "Add failing core tests for an immutable, layered SirenBuilder patch API built from composed pure functions."
  affected_packages = "core"
  details = "Cover `.patch(documents => newDocuments)` as the primitive transform over the builder's document list, then cover `.withDocument`, `.withResource`, `.patchDocument`, and `.patchResource` as convenience wrappers that compose into that pure function layer without mutating the original builder."
}

task cli-mutations-core-patch-api complete {
  description = "Implement an immutable, layered patch API on SirenBuilder."
  affected_packages = "core"
  depends_on = cli-mutations-core-patch-api-red
  details = "Add `.patch(documents => newDocuments)` as the primitive copy-on-write transform, then implement `.withDocument`, `.withResource`, `.patchDocument`, and `.patchResource` as helper layers that compose pure document and resource transforms while preserving the existing build path."
}
# Language renderer replacement
task cli-mutations-language-renderer-red complete {
  description = "Add failing language tests for a literal SirenDocument-to-source renderer."
  affected_packages = "language"
  details = "Cover `renderSirenDocument(document)` rendering directly from literal SirenDocument input, including tasks, milestones, references, quoted identifiers, arrays, and explicit status keywords, without relying on source-preserving trivia or comment retention."
}

task cli-mutations-language-renderer complete {
  description = "Replace language export utilities with a single literal SirenDocument renderer."
  affected_packages = "language"
  depends_on = [cli-mutations-language-renderer-red, cli-mutations-remove-core-export-surface]
  details = "Introduce `renderSirenDocument(document)` as a one-way renderer from literal document IR to Siren source text, delete SirenExporter, exportToSiren, and exportWithComments, and keep any low-level formatting helpers internal to the package."
}
# Package publication boundary
task cli-mutations-publish-core-language complete {
  description = "Publish refreshed core and language package versions so downstream CLI work can consume the new mutation and rendering surfaces."
  affected_packages = "core, language"
  depends_on = [cli-mutations-core-patch-api, cli-mutations-language-renderer]
  details = "Publish new `@sirenpm/core` and `@sirenpm/language` versions after the patch API and renderer land because `@sirenpm/cli` consumes pinned registry packages rather than transparent workspace links."
}
# CLI plumbing and command surface
task cli-mutations-cli-plumbing-red complete {
  description = "Add failing CLI tests for the inverted lifecycle: a single runLifecycle entrypoint that accepts mutate and query hooks and owns all CLI side effects."
  affected_packages = "apps/cli"
  details = "Cover the inverted relationship in apps/cli/src/lifecycle: commands declare pure builder mutations and pure project queries; the lifecycle alone reads files, presents diagnostics to stderr, runs queries, diffs rendered documents against the parse-time snapshot, and writes only files whose output changed. Tests must lock the abort semantics (errors block writes, queries still run on partial IR) and the no-op behavior when no mutate hook is supplied."
}

task cli-mutations-cli-plumbing complete {
  description = "Invert the relationship between command execution and the CLI lifecycle so the lifecycle is a black-box runLifecycle entrypoint and commands describe pure data operations."
  affected_packages = "apps/cli"
  depends_on = [cli-mutations-cli-plumbing-red, cli-mutations-publish-core-language]
  details = "Replace the previous prepare/finalize phase pulls and the global context-store with a single runLifecycle(cwd, { mutate?, query? }) entrypoint. The lifecycle owns discovery, parsing, decoding, builder construction, optional builder mutation, project build, diagnostic accumulation and stderr flushing, optional query execution, write-back of rendered documents that differ from their parse-time snapshot, and query stdout/stderr/exitCode presentation. Commands (`list`, `show`) now return QueryFn closures and never touch fs or stdout directly. `format` remains an intentional exception: it consumes the lifecycle's parsed ctx but performs its own per-file CST rendering â€” tracked as the `format-bypasses-lifecycle` debt entry."
}
# Lifecycle write-back substrate: the explicit per-document rewrite signal
task cli-mutations-writeback-signal-red complete {
  description = "TDD red: failing lifecycle tests for a per-document rewrite signal that drives write-back."
  affected_packages = "apps/cli"
  details = "Cover: the write phase rewrites exactly the documents flagged in an explicit rewrite signal (not a content-divergence diff); the originalFileContents snapshot is gone; signaled documents are written unconditionally; dryRun skips disk writes and reports would-change by comparing ctx.sourceDocuments against parsedDoc.source; verbose lists changed files; a summary line is always emitted. Tests must fail against the current hooks.mutate-gated, content-diffing runWrite."
  files = "apps/cli/src/lifecycle/write.ts, apps/cli/src/lifecycle/context.ts, apps/cli/src/lifecycle/index.ts"
}

task cli-mutations-writeback-signal complete {
  description = "Replace the content-divergence write gate with an explicit per-document rewrite signal owned by the lifecycle write phase."
  affected_packages = "apps/cli"
  depends_on = cli-mutations-writeback-signal-red
  details = "Introduce a rewrite signal (a set of document names) on CliContext. The write phase writes each signaled document's ParsedDocument.source to disk unconditionally and drops the originalFileContents snapshot (redundant with ctx.sourceDocuments). Move dryRun/verbose/summary into the write phase: dryRun skips disk writes and reports would-change via ctx.sourceDocuments vs parsedDoc.source; verbose lists changed files; the summary always prints. Generalize so any signal producer (the bridge or format) flows through this single path. runLifecycle options become { mutate?, query?, format?, dryRun?, verbose? }."
}

task cli-mutations-ir-source-bridge-red complete {
  description = "TDD red: failing tests for the IR-patch to source write-back bridge."
  affected_packages = "apps/cli"
  depends_on = cli-mutations-writeback-signal
  details = "Cover: the mutate hook returns the core PatchResult (builder + EntryChange[]); the bridge maps each 'updated' change to parsedDoc.patchEntry(id, newEntry) on the document named by the original SourcedEntry.origin.document, sourcing the new entry from the post-mutation builder.entries; touched documents are added to the rewrite signal; 'deleted' and 'created' changes are logged and dropped (not applied); a changed id resolving to more than one origin document refuses with an error and writes nothing. Tests must fail against the current BuilderMutate = (builder) => SirenBuilder hook that discards the delta."
  files = "apps/cli/src/lifecycle/mutation.ts, apps/cli/src/lifecycle/write.ts, apps/cli/src/lifecycle/index.ts"
}

task cli-mutations-ir-source-bridge complete {
  description = "Implement the standalone bridge that routes core patch deltas back to per-file ParsedDocument source edits."
  affected_packages = "apps/cli"
  depends_on = cli-mutations-ir-source-bridge-red
  details = "Change BuilderMutate to return the core PatchResult. After diagnostics pass (no EL001 errors), the bridge consumes PatchResult.changes: route each 'updated' entryId via its original SourcedEntry.origin.document to parsedDoc.patchEntry(id, newEntryFromBuilder) and add each touched document to the rewrite signal. Log-and-drop 'deleted'/'created' (no command produces them yet; base mv only emits 'updated'). Refuse (error, no write) when a changed id resolves to multiple origin documents â€” real duplicate-id UX is deferred to cli-mutations-mv-duplicate-id. Remove the now-stale NOTE in write.ts and the 'requires core patch API to return delta' NOTE in index.ts (core@0.6.1 already returns it)."
}
# De-exceptionalize `siren format`: route it through the shared write-back
task cli-mutations-format-lifecycle-red complete {
  description = "TDD red: failing tests/goldens for format routed through the lifecycle write-back."
  affected_packages = "apps/cli"
  depends_on = cli-mutations-writeback-signal
  details = "Cover: runLifecycle(cwd, { format: true }) formats every parsed document in place via ParsedDocument.format() and signals all documents for rewrite; format reuses ctx.parsedDocuments (no fresh parser); the CLI-side semanticKey round-trip check is gone; a parse error (EL001) anywhere aborts the whole write (no per-file skip); dryRun/verbose/summary come from the shared write phase; runFormat is greatly reduced to a flag passthrough. Update the format goldens to the lifecycle path. Tests must fail against the current self-contained runFormat."
  files = "apps/cli/src/commands/format.ts, apps/cli/src/lifecycle/index.ts, apps/cli/test/expected/"
}

task cli-mutations-format-lifecycle complete {
  description = "De-exceptionalize `siren format`: route it through the shared lifecycle write-back as a format-only (no IR mutation) source mutation."
  affected_packages = "apps/cli"
  depends_on = cli-mutations-format-lifecycle-red
  details = "Add a { format: true } option to runLifecycle handled internally: call ParsedDocument.format() on each ctx.parsedDocuments entry and signal all documents. Reduce the format command to runLifecycle(process.cwd(), { format: true, dryRun, verbose }). Delete the fresh-parser path, the semanticKey round-trip check, and the bespoke write/summary logic from format.ts (including the TODO[FORMAT-LIFECYCLE-BYPASS] note). This drops the CLI round-trip comparison entirely (correctness is owned by @sirenpm/language), which resolves the runformat-roundtrip debt â€” mark it complete when this ships."
}

task cli-mutations-mv-command-red complete {
  description = "Add failing unit tests and minimal goldens for the mv status command."
  affected_packages = "apps/cli"
  details = "Add unit tests for mvMutate(entryId, target) factory covering: patches status:'complete' on statusless task; patches status:'draft' on complete task; idempotent same-target returns a no-op PatchResult (empty changes); throws on unknown id; throws on synthesized-only id (materialization deferred); promotes implicit-complete to explicit complete. Add one or two minimal CLI goldens for UX surface: help output, and one end-to-end happy-path filesystem-state fixture. Defer synthesized materialization and duplicate-id handling to follow-up tasks."
}

task cli-mutations-mv-command complete {
  description = "Implement the first mutative command `siren mv <entry-id> <complete|draft>` to change an entry's explicit completion status."
  affected_packages = "apps/cli"
  depends_on = [cli-mutations-mv-command-red, cli-mutations-ir-source-bridge]
  details = "Add apps/cli/src/commands/mv.ts exporting mvMutate factory and mvCommand citty command. Command defines entryId and target (literal 'complete' or 'draft') positional args and calls runLifecycle with the mutate hook. mvMutate searches builder.entries for the entry, throws on unknown or synthesized-only id, and returns builder.patchEntry(id, e => ({ ...e, status })) (a PatchResult). Register mv in mainCommand.subCommands and extend printUsage. The delta-to-source bridge, error/abort wiring, and write-back are owned by cli-mutations-ir-source-bridge and cli-mutations-writeback-signal â€” not this task. Exit 1 on validation error, 0 on success (idempotent no-op => empty delta => no document signaled => no write)."
}
