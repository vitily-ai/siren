{
  "name": "@sirenpm/cli",
  "version": "0.2.0",
  "description": "Siren command-line interface",
  "license": "GPL-3.0",
  "type": "module",
  "bin": {
    "siren": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:quiet": "tsup --silent",
    "prepack": "yarn run build",
    "test": "vitest run --reporter=dot --silent",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sirenpm/core": "0.6.1",
    "@sirenpm/language": "0.5.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
