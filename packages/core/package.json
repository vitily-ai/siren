{
  "name": "@sirenpm/core",
  "version": "0.6.0",
  "description": "Environment-agnostic core library for Siren PMaC",
  "license": "GPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:quiet": "tsup --silent",
    "prepack": "yarn run build",
    "test": "vitest run --reporter=dot --silent",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "deep-freeze-es6": "^5.0.0",
    "klona": "^2.0.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
