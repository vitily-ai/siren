# Trailing comma tests — explicit and implicit tuples with trailing commas
# Trailing commas are syntactically valid and should not produce parse errors

task A {
  description = "Foundation"
}

task B {
  description = "Depends on A"
  # Explicit tuple with trailing comma
  depends_on = [A,]
}

task C {
  description = "Depends on A and B"
  # Explicit tuple with multiple elements and trailing comma
  depends_on = [A, B,]
}

task D {
  description = "Depends on C"
  # Implicit tuple with trailing comma
  depends_on = C,
}

task E {
  description = "Depends on C and D"
  # Implicit tuple with multiple elements and trailing comma
  depends_on = C, D,
}

milestone v1 {
  description = "Version 1"
  # Mixed explicit tuple trailing comma
  depends_on = [A, B, C, D, E,]
}

task F {
  description = "Single explicit tuple with trailing comma"
  # Single-element explicit tuple with trailing comma
  depends_on = [E,]
}
